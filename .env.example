# Optional bootstrap for Anthropic (leave empty and configure in Settings UI after launch)
ANTHROPIC_API_KEY=

# Backend data directory: absolute path, or relative to the backend/ folder (not the shell cwd)
DATA_DIR=./data

# Max sessions in LLM context
MAX_CONTEXT_SESSIONS=20

# Fernet key for encrypting remote_servers plugin SSH credentials at rest.
# If unset, credentials are stored in PLAINTEXT (loud warning at startup).
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back it up like a password-manager master key — losing it makes every
# stored credential unreadable.
CYBEROPS_CREDENTIALS_KEY=

# Plugin signature verification policy:
#   off    (default) — no check, any plugin loads
#   warn   — verify but still load on failure (log warnings; use during transition)
#   strict — refuse to load plugins that don't verify against a trusted key
CYBEROPS_PLUGIN_SIGNATURE_POLICY=off

# Comma-separated list of Ed25519 public keys (base64, optionally prefixed with
# "ed25519:") that are allowed to sign plugins. Generate a keypair with:
#   python -m app.core.plugins.signing generate-key
# Put the PUBLIC key here; keep the PRIVATE key offline and use it to sign
# plugins with `python -m app.core.plugins.signing sign <plugin_dir>`.
CYBEROPS_PLUGIN_TRUSTED_KEYS=

# Capabilities to disable globally regardless of per-plugin manifest
# declarations. Comma-separated. Useful for hardened deployments that
# want to rule out, e.g., shell execution across the board. Known
# capabilities: shell:execute, network:outbound, storage:read_write,
# credentials:read
CYBEROPS_DISABLED_CAPABILITIES=

# Declared bind host for the backend, used by the startup guard in
# app/core/startup_guards.py. The Dockerfile sets this to 0.0.0.0; keep
# matching whatever `uvicorn --host` you actually run with.
CYBEROPS_BIND_HOST=127.0.0.1

# Explicit acknowledgement that an authenticating reverse proxy
# (YubiKey, oauth2-proxy, Cloudflare Access, Tailscale, VPN...) sits in
# front of this backend. Set to exactly "1" to allow CYBEROPS_BIND_HOST
# to be 0.0.0.0 or ::. Without this, the startup guard refuses to run
# on a public bind — stops accidental dev-laptop exposure.
CYBEROPS_TRUST_NETWORK=
